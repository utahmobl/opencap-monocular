# OpenCap API credentials (required)
API_TOKEN=your_opencap_api_token_here
API_URL=https://dev.opencap.ai/ or https://api.opencap.ai/ (for production)

# Internal mono-API settings
# In Docker this is overridden automatically to http://mono-api:8000/
MONO_API_URL=http://127.0.0.1:8000/
MONO_API_KEY=your_mono_api_key_here
REQUIRE_API_KEY=true

# Slack notifications (optional — leave blank to disable)
SLACK_WEBHOOK_URL=
